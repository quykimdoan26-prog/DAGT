#tiếp cận theo Thuật toán Euclid (Euclidean Algorithm).
# giảm bớt số lần lặp so với dùng cộng trừ thông thường.
#kinh điển
class Solution:
    def countOperations(self, num1, num2):
        count = 0
        
        while num1 and num2:
            if num1 >= num2:
                count += num1 // num2
                num1 %= num2
            else:
                count += num2 // num1
                num2 %= num1
        
        return count